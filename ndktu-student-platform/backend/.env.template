# Backend Environment Configuration Template
# Copy this file to .env and update with your actual values

# ═══════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__DATABASE__URL=postgresql+asyncpg://bekzod:YOUR_DB_PASSWORD@database:5432/basic_database
APP_CONFIG__DATABASE__TEST_URL=postgresql+asyncpg://bekzod:YOUR_DB_PASSWORD@localhost:5436/test_db
APP_CONFIG__DATABASE__ECHO=False
APP_CONFIG__DATABASE__ECHO_POOL=False
APP_CONFIG__DATABASE__POOL_SIZE=50
APP_CONFIG__DATABASE__MAX_OVERFLOW=10

# ═══════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__SERVER__APP_PATH=main:app
APP_CONFIG__SERVER__HOST=0.0.0.0
APP_CONFIG__SERVER__PORT=8000

# ═══════════════════════════════════════════════════════════════════
# JWT CONFIGURATION (⚠️ GENERATE SECURE SECRETS!)
# ═══════════════════════════════════════════════════════════════════
# Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_CONFIG__JWT__ACCESS_TOKEN_SECRET=your-access-token-secret-change-this
APP_CONFIG__JWT__REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this
APP_CONFIG__JWT__ACCESS_TOKEN_EXPIRES_MINUTES=30
APP_CONFIG__JWT__REFRESH_TOKEN_EXPIRES_DAYS=7
APP_CONFIG__JWT__ALGORITHM=HS256

# ═══════════════════════════════════════════════════════════════════
# ADMIN CONFIGURATION (⚠️ CHANGE CREDENTIALS!)
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__ADMIN__USERNAME=admin
APP_CONFIG__ADMIN__PASSWORD=your-admin-password-change-this
APP_CONFIG__ADMIN__SECRET_KEY=your-admin-secret-key-change-this

# ═══════════════════════════════════════════════════════════════════
# FILE UPLOAD CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__FILE_URL__HTTP=https://localhost:8000/uploads/questions
APP_CONFIG__FILE_URL__UPLOAD_DIR=uploads/questions

# ═══════════════════════════════════════════════════════════════════
# EXTERNAL APIs CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__HEMIS__LOGIN_URL=https://student.ndki.uz/rest/v1/auth/login
APP_CONFIG__HEMIS__ME_URL=https://student.ndki.uz/rest/v1/account/me

# ═══════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
APP_CONFIG__REDIS__HOST=localhost
APP_CONFIG__REDIS__PORT=6379
APP_CONFIG__REDIS__PREFIX=fastapi-cache

# ═══════════════════════════════════════════════════════════════════
# POSTGRESQL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
POSTGRES_USER=bekzod
POSTGRES_PASSWORD=your-postgres-password-change-this
POSTGRES_DB=basic_database
POSTGRES_HOST=localhost
POSTGRES_PORT=5436

# ═══════════════════════════════════════════════════════════════════
# MONITORING & LOGGING (⚠️ OPTIONAL - ADD YOUR TOKEN IF USING LOGFIRE)
# ═══════════════════════════════════════════════════════════════════
LOGFIRE_PROJECT_NAME=nsumt-tests
LOGFIRE_TOKEN=your-logfire-token-change-this

# ═══════════════════════════════════════════════════════════════════
# Frontend (Vite) environment template.
#
# Setup:
#   1. cp .env.example .env.local
#   2. Override only the values you need — defaults are safe for
#      same-origin proxy setups (nginx in production, Vite in dev).
#
# All variables MUST start with VITE_ to be exposed to the browser.
# See: frontend/src/config/env.ts
# ═══════════════════════════════════════════════════════════════════

# Backend API base URL.
# Default: '/api' (same-origin via nginx/Vite proxy).
# Override only when the API is on a different host.
VITE_API_URL=/api

# Face-detection WebSocket URL used during quiz proctoring.
# Default: same-origin ws(s)://<host>/v1/video/stream
# Override only when the face-detection service is on a different host.
VITE_FACE_DETECTION_SERVICE_URL=

# Toggle quiz proctoring (camera + face detection).
# Set to 'false' to disable; any other value enables.
VITE_ENABLE_QUIZ_PROCTORING=true

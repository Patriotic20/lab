# ═══════════════════════════════════════════════════════════════════
# Root .env template — used by docker-compose for backend,
# face-detection, postgres, redis, and pgadmin services.
#
# Setup:
#   1. cp .env.example .env
#   2. Fill in real values for every <CHANGE_ME> placeholder.
#   3. NEVER commit the real .env — it is gitignored.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ═══════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_USER=<CHANGE_ME_DB_USER>
POSTGRES_PASSWORD=<CHANGE_ME_DB_PASSWORD>
POSTGRES_DB=basic_database

APP_CONFIG__DATABASE__URL=postgresql+asyncpg://<CHANGE_ME_DB_USER>:<CHANGE_ME_DB_PASSWORD>@database:5432/basic_database
APP_CONFIG__DATABASE__TEST_URL=postgresql+asyncpg://<CHANGE_ME_DB_USER>:<CHANGE_ME_DB_PASSWORD>@database:5432/test_db
APP_CONFIG__DATABASE__ECHO=False
APP_CONFIG__DATABASE__ECHO_POOL=False
APP_CONFIG__DATABASE__POOL_SIZE=50
APP_CONFIG__DATABASE__MAX_OVERFLOW=10

# ─── Backend server ────────────────────────────────────────────────
APP_CONFIG__SERVER__APP_PATH=app.main:app
APP_CONFIG__SERVER__HOST=0.0.0.0
APP_CONFIG__SERVER__PORT=8000
# Set to True in production — disables /docs, /redoc, /openapi.json.
APP_CONFIG__SERVER__IS_PROD=False

# ─── JWT (rotate if leaked) ────────────────────────────────────────
APP_CONFIG__JWT__ACCESS_TOKEN_SECRET=<CHANGE_ME_JWT_ACCESS_SECRET>
APP_CONFIG__JWT__REFRESH_TOKEN_SECRET=<CHANGE_ME_JWT_REFRESH_SECRET>
APP_CONFIG__JWT__ACCESS_TOKEN_EXPIRES_MINUTES=30
APP_CONFIG__JWT__REFRESH_TOKEN_EXPIRES_DAYS=7
APP_CONFIG__JWT__ALGORITHM=HS256

# ─── File uploads ──────────────────────────────────────────────────
APP_CONFIG__FILE_URL__HTTP=https://lms.nsumt.uz/uploads/questions
APP_CONFIG__FILE_URL__UPLOAD_DIR=uploads/questions

# ─── Hemis external API ────────────────────────────────────────────
APP_CONFIG__HEMIS__LOGIN_URL=https://student.ndki.uz/rest/v1/auth/login
APP_CONFIG__HEMIS__ME_URL=https://student.ndki.uz/rest/v1/account/me

# ─── Redis ─────────────────────────────────────────────────────────
APP_CONFIG__REDIS__HOST=redis
APP_CONFIG__REDIS__PORT=6379
APP_CONFIG__REDIS__PREFIX=fastapi-cache

# ─── CORS ──────────────────────────────────────────────────────────
# JSON-форматированный список разрешённых origin'ов. Пустой список = ничего не пускать.
# Пример для прод+дев:
#   APP_CONFIG__CORS__ORIGINS=["https://lms.api.nsumt.uz","http://localhost:3000","http://localhost:5173"]
APP_CONFIG__CORS__ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://lms.api.nsumt.uz","https://lms.api.nsumt.uz"]

# ─── Face detection microservice (shared secret) ───────────────────
# The same value must be set as INTERNAL_SERVICE_TOKEN below.
APP_CONFIG__FACE_SERVICE__URL=http://face-detection:8000
APP_CONFIG__FACE_SERVICE__INTERNAL_TOKEN=<CHANGE_ME_FACE_SERVICE_TOKEN>

# Face detection service config (consumed inside face-detection container)
MODEL_PATH=/face/blaze_face_short_range.tflite
LOG_LEVEL=INFO
INTERNAL_SERVICE_TOKEN=<CHANGE_ME_FACE_SERVICE_TOKEN>

# ─── Traefik / Let's Encrypt (production only) ─────────────────────
ACME_EMAIL=<CHANGE_ME_ACME_EMAIL>

# ─── PgAdmin ───────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=<CHANGE_ME_PGADMIN_EMAIL>
PGADMIN_DEFAULT_PASSWORD=<CHANGE_ME_PGADMIN_PASSWORD>

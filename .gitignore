# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# ── IDEs ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Env files (never commit real secrets) ─────────────────────
.env
.env.*
!.env.example
!.env.template

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
dist/
build/
.vite/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml

# ── Persistent data / volumes ─────────────────────────────────
postgres_data_quiz/
redis_data/
pgadmin_data/
grafana_data/
loki_data/
prometheus_data/

# ── App runtime ───────────────────────────────────────────────
backend/logs/
frontend/logs/
backend/uploads/

# ── Backups / dumps / exports ─────────────────────────────────
backups/
backup_*.sql
backup_*.sql.gz
*.dump

# ── Generated / tooling artifacts ─────────────────────────────
repomix-output.xml
.claude/plans/
.claude/memory/

# ── Screenshots & browser-automation output ───────────────────
# Throwaway artifacts from Playwright / MCP sessions and ad-hoc screenshots.
# Real frontend assets live in frontend/public/ — those are not affected.
screenshots/*
!screenshots/.gitkeep
.playwright-mcp/

# Loose images dropped into the project root (drag-drop in IDE, etc.) —
# almost always accidental. Anchored with leading "/" so frontend/public/*.png
# and frontend/src/assets/*.png stay tracked.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# Common IDE/OS screenshot filename patterns (anywhere in tree)
Screenshot*.png
screenshot*.png
Снимок*.png
image*.png

examples/
